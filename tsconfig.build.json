{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationDir": "dist",
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "stripInternal": true
  },
  "include": ["src"],
  "exclude": ["**/*.stories.*", "demo", "dist"]
}
