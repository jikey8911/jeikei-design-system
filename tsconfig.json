{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@jeikei/tokens": ["src/tokens"],
      "@jeikei/components": ["src/components"],
      "@jeikei/neural": ["src/neural"],
      "@jeikei/hooks": ["src/hooks"],
      "@jeikei/utils": ["src/utils"]
    }
  },
  "include": ["src", "demo", ".storybook"]
}
